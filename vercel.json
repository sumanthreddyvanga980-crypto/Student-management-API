{
  "version": 3,
  "builds": [
    {
      "src": "student-management/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/student-management/app.py"
    }
  ],
  "functions": {
    "student-management/app.py": {
      "runtime": "python3.12"
    }
  }
}
